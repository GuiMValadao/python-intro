    {
      "id": "l5LjTc7qs3C9sHo4MXOAW",
      "type": "text",
      "x": -2117.4900148908987,
      "y": -1251.364345481853,
      "width": 506.1197814941406,
      "height": 350,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
