    },
    {
      "id": "E0ahoaH2497JeHheekY9D",
      "type": "text",
      "x": -2641.8032068785164,
      "y": -1484.6333638427818,
      "width": 454.1797180175781,
      "height": 800,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "AEJXjqA32bJQy3aHpd8Wt"
      ],
      "frameId": null,
      "index": "a8",
      "roundness": null,
      "seed": 1674304864,
      "version": 1356,
      "versionNonce": 1498254688,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777244037183,
      "link": null,
      "locked": false,
      "text": "methods:\n    __init__:\n        Initialize pygame, game screen\n        load background images\n        properties: \n            clock, \n            player(Player class from entities.py),\n            current state (GameState class\n            from config.py), \n            battle_event (is created inside game\n            logic),\n            note_sounds (for playing sounds in\n            exploration mode; might be good to \n            move it to the player class instead \n            of here),\n            menus (main, options, pause, from\n            menu.py),\n            maps (all maps, from maps.py),\n            current_map,\n            camera (from maps.py),\n            player_position.\n    reset_game (reset entities after ending\n        the game)\n    run (main game loop, handles the events,\n        updates screen, draw objects, controls\n        the clock frame generation)\n    set_state (takes a state as argument to\n        change the game accordingly, and apply\n        appropriate logic for different states\n        when necessary)\n    \n    ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "methods:\n    __init__:\n        Initialize pygame, game screen\n        load background images\n        properties: \n            clock, \n            player(Player class from entities.py),\n            current state (GameState class\n            from config.py), \n            battle_event (is created inside game\n            logic),\n            note_sounds (for playing sounds in\n            exploration mode; might be good to \n            move it to the player class instead \n            of here),\n            menus (main, options, pause, from\n            menu.py),\n            maps (all maps, from maps.py),\n            current_map,\n            camera (from maps.py),\n            player_position.\n    reset_game (reset entities after ending\n        the game)\n    run (main game loop, handles the events,\n        updates screen, draw objects, controls\n        the clock frame generation)\n    set_state (takes a state as argument to\n        change the game accordingly, and apply\n        appropriate logic for different states\n        when necessary)\n    \n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
