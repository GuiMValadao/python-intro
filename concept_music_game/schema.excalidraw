    {
      "id": "7-iU4N0UExei0siA6VXKs",
      "type": "text",
      "x": -352.61040428354,
      "y": -637.7203991701898,
      "width": 526.1878051757812,
      "height": 428.13762278964833,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
