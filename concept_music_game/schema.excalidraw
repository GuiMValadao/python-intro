      "seed": 1965517984,
      "version": 2231,
      "versionNonce": 2128572768,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777241574457,
      "link": null,
      "locked": false,
      "text": "Important values to keep in mind:\n    INSTRUMENT -> this will allow changing \nbetween instruments, the value is the name \nof the folder holding the notes. Refer to \nacoustic_guitar for the necessary files.\n    NOTES_TO_KEYS -> defines the keyboard\nkeys to be pressed for playing. Is the only place\nthis is defined, to change it is only necessary\nto change here. SHARP_MODIFIER e FLAT_\nMODIFIER are also here.\n    EXTENDED_NOTE_NAMES -> refer to this dict\nto create songs.\n    \n    ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Important values to keep in mind:\n    INSTRUMENT -> this will allow changing \nbetween instruments, the value is the name \nof the folder holding the notes. Refer to \nacoustic_guitar for the necessary files.\n    NOTES_TO_KEYS -> defines the keyboard\nkeys to be pressed for playing. Is the only place\nthis is defined, to change it is only necessary\nto change here. SHARP_MODIFIER e FLAT_\nMODIFIER are also here.\n    EXTENDED_NOTE_NAMES -> refer to this dict\nto create songs.\n    \n    ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
