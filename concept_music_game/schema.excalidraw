    {
      "id": "G6nRd56s1zoNyOx1J2ACO",
      "type": "text",
      "x": -353.6858628101513,
      "y": -1066.9468681798314,
      "width": 521.2425537109375,
      "height": 261.6396583714518,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "dkG3sssizpbzbACs-uGO4"
      ],
      "frameId": null,
      "index": "aU",
      "roundness": null,
      "seed": 875431264,
      "version": 4210,
      "versionNonce": 1105696928,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1777243847866,
      "link": null,
      "locked": false,
      "text": "Holds all songs. The file contains the expected format\nfor the songs, which consists in a dict with two keys,\nkey_signature and notes, the key_signature containing\nthe key of the song, as well as allowing switching the\nkey in the middle of the songs. The values for the \nnotes key will be a list of tuples; each individual tuple\ncontains the frame_time which the note should appear\nand a list containing the note or notes (at max 3) that\nshould appear during that frame. In the end of the file\nthere is a SONGS dict which centralizes the songs in\none variable, making it easier to work with.",
      "fontSize": 19.028338790651038,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Holds all songs. The file contains the expected format\nfor the songs, which consists in a dict with two keys,\nkey_signature and notes, the key_signature containing\nthe key of the song, as well as allowing switching the\nkey in the middle of the songs. The values for the \nnotes key will be a list of tuples; each individual tuple\ncontains the frame_time which the note should appear\nand a list containing the note or notes (at max 3) that\nshould appear during that frame. In the end of the file\nthere is a SONGS dict which centralizes the songs in\none variable, making it easier to work with.",
      "autoResize": true,
      "lineHeight": 1.25
    },
