    {
      "id": "nM03xK1y4mW5sK_wasAmd",
      "type": "text",
      "x": -1551.347819630749,
      "y": -1507.6127093535538,
      "width": 522.6690673828125,
      "height": 998.9877865091794,
      "angle": 0,
      "strokeColor": "#2f9e44",
